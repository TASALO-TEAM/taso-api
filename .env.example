# =============================================================================
# TASALO-API - Configuración de Variables de Entorno
# =============================================================================
# Copia este archivo a .env y ajusta los valores según tu entorno.
# NO commitear el archivo .env con valores reales (está en .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Database - Conexión a la base de datos
# -----------------------------------------------------------------------------
# Desarrollo local: SQLite con aiosqlite (async)
DATABASE_URL=sqlite+aiosqlite:///./tasalo.db
#
# Producción: PostgreSQL con asyncpg
# DATABASE_URL=postgresql+asyncpg://usuario:password@localhost:5432/tasalo
#
# Notas:
# - SQLite es suficiente para desarrollo y testing
# - PostgreSQL recomendado para producción
# - El engine se crea automáticamente al iniciar la app

# -----------------------------------------------------------------------------
# ElToque API - Fuente de tasas del mercado informal
# -----------------------------------------------------------------------------
# API Key proporcionada por ElToque (requiere registro)
ELTOQUE_API_KEY=your_eltoque_api_key_here
#
# URL del endpoint de tasas (no modificar salvo cambios en la API)
ELTOQUE_API_URL=https://tasas.eltoque.com/v1/trmi
#
# Notas:
# - La API de ElToque requiere autenticación con Bearer token
# - Timeout configurado: 10 segundos por defecto

# -----------------------------------------------------------------------------
# Security - Autenticación para endpoints administrativos
# -----------------------------------------------------------------------------
# API Key para proteger endpoints /api/v1/admin/*
# IMPORTANTE: Cambiar en producción por un valor seguro y único
ADMIN_API_KEY=your_secret_admin_key_here
#
# Recomendaciones:
# - Usar al menos 32 caracteres aleatorios
# - Generar con: openssl rand -hex 32
# - Almacenar en gestor de secretos en producción

# -----------------------------------------------------------------------------
# Scheduler - Intervalo de actualización automática de tasas
# -----------------------------------------------------------------------------
# Cada cuántos minutos se ejecuta el refresh automático de tasas
REFRESH_INTERVAL_MINUTES=5
#
# Rango válido: 1-60 minutos
# - 5 min: Recomendado para desarrollo y producción
# - 1 min: Máxima frecuencia (puede saturar fuentes externas)
# - 15+ min: Para entornos de testing con recursos limitados

# -----------------------------------------------------------------------------
# CORS - Control de acceso desde navegadores
# -----------------------------------------------------------------------------
# Orígenes permitidos para hacer requests desde el navegador
# Separar múltiples orígenes por coma (sin espacios)
ALLOWED_ORIGINS=*
#
# Ejemplos:
# - Desarrollo local: http://localhost:3000,http://localhost:8080
# - Producción: https://miniapp.tasalo.com,https://extension.tasalo.com
# - Todos los orígenes: * (no recomendado en producción)
#
# Notas:
# - El asterisco (*) permite todos los orígenes (solo desarrollo)
# - En producción, especificar explícitamente los dominios permitidos
# - La API también puede ser consumida desde servidores (no afecta CORS)

# -----------------------------------------------------------------------------
# Server - Configuración del servidor HTTP
# -----------------------------------------------------------------------------
# Puerto en el que escucha la API
PORT=8040
#
# Notas:
# - Desarrollo: 8040 (o cualquier puerto libre)
# - Producción: 80 o 443 (con reverse proxy)
# - El puerto se pasa a uvicorn: uvicorn src.main:app --port $PORT

# -----------------------------------------------------------------------------
# Logging - Nivel de detalle de logs (opcional)
# -----------------------------------------------------------------------------
# Niveles disponibles: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO
#
# Notas:
# - DEBUG: Máximo detalle (solo desarrollo)
# - INFO: Operaciones normales (producción)
# - WARNING: Solo advertencias y errores
# - Por defecto: INFO si no se especifica

# ============================================
# Redis Configuration
# ============================================
# URL de conexión a Redis para caching
# Formato: redis://[host]:[port]/[db]
REDIS_URL=redis://localhost:6379/0
#
# Tiempo de vida (TTL) por defecto para caché de Cubanomic en segundos
# 86400 = 24 horas, 3600 = 1 hora, 600 = 10 minutos
REDIS_TTL_CUBANOMIC=86400
#
# Notas:
# - Redis es opcional para desarrollo (la app funciona sin él)
# - En producción, usar Redis para mejorar rendimiento
# - El cliente Redis maneja reconexión automática
# - Pool de conexiones: máximo 10 conexiones concurrentes
